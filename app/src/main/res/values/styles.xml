<resources>
    <!-- Base application theme. -->
    <style name="Theme.UnifiedLauncher" parent="Theme.Material3.DayNight">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_light_onSecondaryContainer</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/md_theme_light_primaryContainer</item>
        <!-- Customize your theme here. -->
    </style>

    <!-- Theme for the Honeycomb launcher activity.
         No parent — matches the working standalone source exactly.
         windowShowWallpaper + windowNoTitle replicate what Theme.Wallpaper.NoTitleBar provides
         without pulling in any Holo/AppCompat TabWidget overrides. -->
    <style name="Theme.Launcher3H" parent="android:Theme">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowShowWallpaper">true</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>
</resources>
